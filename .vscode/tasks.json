{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Backend Django",
			"type": "shell",
			"command": ".\\.venv\\Scripts\\python.exe",
			"args": [
				"backend\\manage.py",
				"runserver",
				"127.0.0.1:8000"
			],
			"isBackground": true
		},
		{
			"label": "Run Frontend Vite",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--",
				"--host",
				"127.0.0.1",
				"--port",
				"5173"
			],
			"isBackground": true
		},
		{
			"label": "Run Backend Django SQLite",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-Command",
				"Set-Location backend; $env:DB_ENGINE='sqlite'; ..\\.venv\\Scripts\\python.exe manage.py runserver 127.0.0.1:8000"
			],
			"isBackground": true
		},
		{
			"label": "Run Frontend Vite App",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-Command",
				"Set-Location frontend; npm run dev -- --host 127.0.0.1 --port 5173"
			],
			"isBackground": true
		},
		{
			"label": "Run Backend Django SQLite Fixed",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-Command",
				"Set-Location backend; $env:DB_ENGINE=\"sqlite\"; ..\\.venv\\Scripts\\python.exe manage.py runserver 127.0.0.1:8000"
			],
			"isBackground": true
		}
	]
}